# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Environment
NODE_ENV=production

# Server
PORT=3000

# Frontend URL (used for CORS)
FRONTEND_URL=https://your-domain.com

# MongoDB
DB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>

# JWT secrets — generate with: openssl rand -hex 32
# Must be two DIFFERENT secrets!
JWT_SECRET=<openssl rand -hex 32>
JWT_REFRESH_SECRET=<openssl rand -hex 32>

# Admin credentials
# Username is plain text
ADMIN_USERNAME=admin
# Password must be a bcrypt hash (cost factor 12)
# Generate with: node -e "const b=require('bcrypt');b.hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=$2b$12$replacethiswithyourrealbcrypthash

# Cloudinary
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_KEY=your_api_key
CLOUDINARY_SECRET=your_api_secret
